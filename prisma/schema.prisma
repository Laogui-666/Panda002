// 沐海旅行签证ERP系统 - Prisma数据模型
// 多租户架构 + 扁平化部门角色体系
// 主机: rm-bp159g3iw669447778o.mysql.rds.aliyuncs.com
// 端口: 3306
// 数据库: visa
// 用户: visa

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 角色枚举 ============
// 账号权限体系 (9级角色 - 扁平化部门架构)
// 权限层级说明：
// 1. SUPER_ADMIN - 超级管理员: 网站最高权限，管理所有入驻公司
// 2. COMPANY_OWNER - 公司负责人: 公司最高权限，直管客服部、签证部、外包业务员
// 3. CS_ADMIN - 客服部管理员: 客服部门最高权限，管理客服团队
// 4. CUSTOMER_SERVICE - 客服: 负责录入订单，与客户对接
// 5. VISA_ADMIN - 签证部管理员: 签证部门最高权限，管理资料员和签证操作员
// 6. DOC_COLLECTOR - 资料员: 负责收集客户资料，与客户对接
// 7. OPERATOR - 签证操作员: 负责审核资料、制作签证材料
// 8. OUTSOURCE - 外包业务员: 受限权限，直属于公司负责人
// 9. CUSTOMER - 普通用户: 客户端用户，只能从"我的订单"进入查看
// 部门架构（扁平化）：
// 公司负责人(COMPANY_OWNER)
// ├── 客服部: 客服部管理员(CS_ADMIN) → 客服(CUSTOMER_SERVICE)
// ├── 签证部: 签证部管理员(VISA_ADMIN) → 资料员 + 签证操作员
// ├── 外包业务员(OUTSOURCE) → 直属于公司负责人
// └── 综合部(预留): 财务、人事等
enum UserRole {
  SUPER_ADMIN       // 超级管理员: 网站最高权限，管理所有入驻公司
  COMPANY_OWNER    // 公司负责人: 公司最高权限，直管客服部、签证部、外包业务员
  CS_ADMIN         // 客服部管理员: 客服部门最高权限，管理客服团队
  CUSTOMER_SERVICE // 客服: 负责录入订单，与客户对接
  VISA_ADMIN       // 签证部管理员: 签证部门最高权限，管理资料员和签证操作员
  DOC_COLLECTOR    // 资料员: 负责客户资料收集与对接
  OPERATOR         // 签证操作员: 负责审核资料、制作签证材料
  OUTSOURCE        // 外包业务员: 受限权限，直属于公司负责人
  CUSTOMER         // 普通用户: 客户端用户，只能从"我的订单"进入查看
}

// ============ 订单状态枚举 ============
enum OrderStatus {
  PENDING_CONNECTION  // 待对接
  CONNECTED          // 已对接
  COLLECTING_DOCS    // 资料收集中
  PENDING_REVIEW     // 待审核
  UNDER_REVIEW       // 资料审核中
  MAKING_MATERIALS   // 材料制作中
  PENDING_DELIVERY   // 待交付
  DELIVERED          // 已交付
  APPROVED           // 出签
  REJECTED           // 拒签
}

// ============ 资料状态枚举 ============
enum DocumentStatus {
  PENDING   // 待上传/待审核
  APPROVED  // 合格
  REJECTED  // 打回
}

// ============ 资料员操作状态 ============
enum DocumentReviewStatus {
  PENDING   // 待传
  PENDING_REVIEW  // 待审
  APPROVED  // 合格
  REJECTED  // 打回
}

// ============ 预约状态 ============
enum AppointmentStatus {
  SCHEDULED  // 已预约
  COMPLETED  // 已完成
  CANCELLED  // 已取消
}

// ============ 用户状态 ============
enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

// ============ 公司表 ============
model Company {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)    // 公司名称
  shortName String?   @db.VarChar(50)     // 简称
  logo      String?   @db.VarChar(255)    // Logo URL
  phone     String?   @db.VarChar(20)     // 联系电话
  email     String?   @db.VarChar(100)    // 邮箱
  address   String?   @db.VarChar(255)    // 地址
  status    String    @default("active")  // active/inactive
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // 关联
  users        User[]
  departments  Department[]
  orders       Order[]
  customers    Customer[]
}

// ============ 部门表 ============
model Department {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)    // 部门名称
  code        String?   @db.VarChar(50)     // 部门编码
  description String?   @db.Text             // 描述
  parentId    Int?                            // 父部门ID
  leaderId    Int?                            // 负责人ID
  status      String    @default("active")  // active/inactive
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 外键
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id])

  // 自关联
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")

  // 关联
  users       User[]
  orders      Order[]

  @@index([companyId])
  @@index([parentId])
}

// ============ 用户表 ============
model User {
  id           Int        @id @default(autoincrement())
  email        String?    @unique @db.VarChar(100)
  username     String     @unique @db.VarChar(50)   // 用户名
  passwordHash String     @db.VarChar(255)          // 密码哈希
  name         String     @db.VarChar(50)           // 真实姓名
  phone        String?    @db.VarChar(20)           // 电话
  avatar       String?    @db.VarChar(255)          // 头像URL
  role         UserRole   @default(CUSTOMER)        // 角色
  status       UserStatus @default(ACTIVE)          // 状态
  lastLoginAt  DateTime?                            // 最后登录时间
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // 外键
  companyId    Int?
  company      Company?    @relation(fields: [companyId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  // 关联
  customer          Customer?        @relation("UserCustomer")
  ordersAsCs        Order[]          @relation("OrderCs")
  ordersAsDc        Order[]          @relation("OrderDc")
  ordersAsOp        Order[]          @relation("OrderOp")
  orderLogs         OrderLog[]
  loginLogs         LoginLog[]
  visaMaterials     VisaMaterial[]
  notifications     Notification[]
  smsLogs           SmsLog[]

  @@index([companyId])
  @@index([departmentId])
  @@index([role])
}

// ============ 客户表 ============
model Customer {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)     // 客户姓名
  phone        String?   @db.VarChar(20)      // 电话
  email        String?   @db.VarChar(100)     // 邮箱
  passportNo   String?   @db.VarChar(50)      // 护照号
  idCardNo     String?   @db.VarChar(20)      // 身份证号
  gender       String?   @db.VarChar(10)      // 性别
  birthDate    DateTime?                         // 出生日期
  nationality String?   @db.VarChar(50)      // 国籍
  address      String?   @db.VarChar(255)     // 地址
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 外键
  companyId    Int
  company      Company   @relation(fields: [companyId], references: [id])
  userId        Int?     @unique                        // 关联登录账号
  user         User?     @relation("UserCustomer", fields: [userId], references: [id])

  // 关联
  orders       Order[]

  @@index([companyId])
  @@index([userId])
  @@index([phone])
}

// ============ 订单表 ============
model Order {
  id              Int          @id @default(autoincrement())
  orderNo         String       @unique @db.VarChar(50)    // 订单号
  
  // 签证信息 (冗余存储，便于查询)
  visaCountry     String       @db.VarChar(50)             // 签证国家
  visaType        String       @db.VarChar(50)             // 签证类型
  entryType       String?      @db.VarChar(20)             // 入境类型(单次/多次)
  stayDuration    Int?                                   // 停留天数
  validityDays    Int?                                   // 有效期天数
  
  // 签证线路关联
  visaLineId      Int?                                    // 签证线路ID
  visaLine        VisaLine?   @relation(fields: [visaLineId], references: [id])
  
  // 状态
  status          OrderStatus  @default(PENDING_CONNECTION)
  appointmentDate DateTime?                              // 预约日期
  submissionDate  DateTime?                              // 提交日期
  deliveryDate    DateTime?                              // 交付日期
  resultDate      DateTime?                              // 出结果日期
  
  // 金额
  visaFee         Decimal?     @db.Decimal(10, 2)        // 签证费
  serviceFee      Decimal?     @db.Decimal(10, 2)        // 服务费
  totalFee        Decimal?     @db.Decimal(10, 2)       // 总费用
  paymentStatus   String       @default("unpaid")        // 支付状态: unpaid/paid
  
  // 备注
  remark          String?      @db.Text                   // 备注
  rejectReason    String?      @db.Text                   // 拒签原因
  
  // 时间戳
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // 外键
  companyId       Int
  company         Company      @relation(fields: [companyId], references: [id])
  customerId      Int
  customer        Customer     @relation(fields: [customerId], references: [id])
  
  // 受理人员
  csId            Int?                                    // 客服ID
  cs              User?        @relation("OrderCs", fields: [csId], references: [id])
  dcId            Int?                                    // 资料员ID
  dc              User?        @relation("OrderDc", fields: [dcId], references: [id])
  opId            Int?                                    // 操作员ID
  op              User?        @relation("OrderOp", fields: [opId], references: [id])
  
  // 部门
  departmentId    Int?
  department      Department?  @relation(fields: [departmentId], references: [id])

  // 关联
  documentRequirements DocumentRequirement[]
  visaMaterials       VisaMaterial[]
  orderLogs           OrderLog[]
  appointments        Appointment[]
  notifications      Notification[]
  smsLogs            SmsLog[]

  @@index([companyId])
  @@index([customerId])
  @@index([csId])
  @@index([dcId])
  @@index([opId])
  @@index([status])
  @@index([orderNo])
}

// ============ 资料清单表(客户需要上传的资料) ============
model DocumentRequirement {
  id           Int                  @id @default(autoincrement())
  name         String               @db.VarChar(100)    // 资料名称
  description  String?              @db.VarChar(255)    // 资料描述
  isRequired  Boolean              @default(true)      // 是否必填
  sortOrder    Int                  @default(0)         // 排序
  
  // 状态
  status       DocumentReviewStatus @default(PENDING)   // 待传/待审/合格/打回
  rejectReason String?              @db.Text           // 打回原因
  fileUrl      String?              @db.VarChar(500)   // 文件URL
  uploadedAt  DateTime?                                 // 上传时间
  reviewedAt  DateTime?                                 // 审核时间
  reviewedBy  Int?                                       // 审核人ID
  
  // 外键
  orderId      Int
  order        Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([orderId])
  @@index([status])
}

// ============ 签证材料表(制作出的材料) ============
model VisaMaterial {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(100)    // 材料名称
  type         String        @db.VarChar(50)     // 材料类型
  fileUrl      String?       @db.VarChar(500)    // 文件URL
  
  // 状态
  status       DocumentStatus @default(PENDING)   // 待审/合格/打回
  rejectReason String?       @db.Text            // 打回原因
  reviewedAt  DateTime?                          // 审核时间
  
  // 外键
  orderId      Int
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy    Int?
  creator      User?         @relation(fields: [createdBy], references: [id])
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

// ============ 订单日志表 ============
model OrderLog {
  id          Int       @id @default(autoincrement())
  action      String    @db.VarChar(50)       // 操作动作
  content     String?   @db.Text              // 操作内容
  fromStatus  String?   @db.VarChar(50)       // 原状态
  toStatus    String?   @db.VarChar(50)       // 新状态
  
  // 外键
  orderId     Int
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  
  createdAt   DateTime  @default(now())

  @@index([orderId])
  @@index([userId])
}

// ============ 预约表 ============
model Appointment {
  id               Int              @id @default(autoincrement())
  appointmentDate  DateTime          // 预约日期
  appointmentTime  String?          @db.VarChar(20)     // 预约时间
  location         String?          @db.VarChar(200)    // 地点
  contactPerson    String?          @db.VarChar(50)     // 联系人
  contactPhone     String?          @db.VarChar(20)     // 联系电话
  status           AppointmentStatus @default(SCHEDULED)
  remark           String?          @db.Text            // 备注
  documentPath     String?          @db.VarChar(500)    // 材料路径
  
  // 外键
  orderId          Int
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([orderId])
  @@index([appointmentDate])
}

// ============ 通知类型枚举 ============
enum NotificationType {
  NEW_ORDER           // 新订单
  ORDER_ACCEPTED      // 订单已接
  DOC_UPLOADED        // 资料已上传
  DOC_APPROVED        // 资料已合格
  DOC_REJECTED        // 资料已打回
  DOC_NEED_MORE       // 需要补充资料
  ORDER_SUBMITTED     // 已提交审核
  ORDER_IN_REVIEW     // 审核中
  MATERIAL_READY      // 材料已就绪
  ORDER_DELIVERED     // 已交付
  ORDER_APPROVED      // 已出签
  ORDER_REJECTED      // 已拒签
  APPOINTMENT_REMINDER // 预约提醒
  SYSTEM_MESSAGE      // 系统消息
}

// ============ 登录日志表 ============
model LoginLog {
  id           Int       @id @default(autoincrement())
  ipAddress    String?   @db.VarChar(50)      // IP地址
  userAgent    String?   @db.Text             // 用户代理
  loginStatus  String    @default("success")  // success/failed
  failReason   String?   @db.VarChar(255)     // 失败原因
  
  // 外键
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============ 通知表 ============
model Notification {
  id           Int       @id @default(autoincrement())
  type         NotificationType @default(SYSTEM_MESSAGE)
  title        String    @db.VarChar(100)
  content      String    @db.Text
  link         String?   @db.VarChar(255)
  isRead       Boolean   @default(false)
  priority     String    @default("normal")
  
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  orderId      Int?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime  @default(now())
  readAt       DateTime?

  @@index([userId])
  @@index([orderId])
  @@index([isRead])
  @@index([createdAt])
}

// ============ 短信模板表 ============
model SmsTemplate {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)
  name         String    @db.VarChar(100)
  content      String    @db.Text
  variables    String?   @db.VarChar(255)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ============ 签证国家表 ============
model VisaCountry {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)    // 国家名称
  code        String    @unique @db.VarChar(10)    // 国家代码 (如: US, JP, UK)
  flag        String?   @db.VarChar(255)    // 国旗URL
  continent   String?   @db.VarChar(50)    // 所属洲
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联
  visaLines   VisaLine[]

  @@index([isActive])
}

// ============ 签证类型枚举 ============
enum VisaCategory {
  TOURISM       // 旅游签证
  BUSINESS      // 商务签证
  WORK          // 工作签证
  STUDY         // 学生签证
  TRANSIT       // 过境签证
  FAMILY        // 探亲访友签证
  OTHER         // 其他签证
}

// ============ 签证线路表 ============
model VisaLine {
  id              Int         @id @default(autoincrement())
  name            String      @db.VarChar(100)    // 线路名称
  countryId       Int                                    // 国家ID
  country         VisaCountry @relation(fields: [countryId], references: [id])
  
  // 签证类型
  category        VisaCategory @default(TOURISM)  // 签证大类
  visaType        String      @db.VarChar(50)     // 具体签证类型名称
  entryType       String?     @db.VarChar(20)     // 入境类型(单次/两次/多次)
  
  // 基本参数
  validityDays    Int?                                   // 有效期(天)
  maxStayDays     Int?                                   // 最多停留天数
  processingDays  Int?                                   // 办理天数
  interview       Boolean  @default(false)             // 是否需要面试
  invitation      Boolean  @default(false)             // 是否需要邀请函
  
  // 费用
  visaFee         Decimal?   @db.Decimal(10, 2)    // 签证费
  serviceFee      Decimal?   @db.Decimal(10, 2)   // 服务费
  expressFee      Decimal?   @db.Decimal(10, 2)   // 加急费
  
  // 描述
  description     String?    @db.Text             // 线路描述
  requirements    String?    @db.Text             // 办理要求
  materials       String?    @db.Text             // 材料说明
  
  // 状态
  isActive        Boolean    @default(true)
  isPopular       Boolean    @default(false)      // 是否热门
  sortOrder       Int        @default(0)
  
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // 关联
  documentReqs    VisaLineDocument[]
  orders          Order[]

  @@index([countryId])
  @@index([category])
  @@index([isActive])
}

// ============ 签证线路资料清单表 ============
model VisaLineDocument {
  id              Int         @id @default(autoincrement())
  visaLineId      Int                                    // 签证线路ID
  visaLine        VisaLine   @relation(fields: [visaLineId], references: [id], onDelete: Cascade)
  
  // 资料信息
  name            String      @db.VarChar(100)    // 资料名称
  description     String?     @db.VarChar(255)   // 资料描述
  category        String?     @db.VarChar(50)    // 资料分类 (身份证明/资产证明/工作证明等)
  
  // 规则
  isRequired      Boolean     @default(true)      // 是否必填
  isMultiple      Boolean     @default(false)     // 是否可上传多份
  fileType        String?     @db.VarChar(50)     // 允许的文件类型 (pdf,jpg,png)
  maxFileSize     Int?                                // 最大文件大小(MB)
  
  // 模板
  templateUrl     String?     @db.VarChar(500)   // 材料模板URL
  templateDesc    String?     @db.Text           // 模板说明
  
  // 排序
  sortOrder       Int         @default(0)
  
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([visaLineId])
}

// ============ 短信发送记录表 ============
model SmsLog {
  id           Int       @id @default(autoincrement())
  phone        String    @db.VarChar(20)
  templateCode String?   @db.VarChar(50)
  content      String    @db.Text
  status       String    @default("pending")
  errorMsg     String?   @db.VarChar(255)
  sentAt       DateTime?
  orderId      Int?
  order        Order?   @relation(fields: [orderId], references: [id])
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())

  @@index([phone])
  @@index([orderId])
  @@index([status])
}

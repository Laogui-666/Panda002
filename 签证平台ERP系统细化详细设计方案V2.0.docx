### 3.3 站内聊天接口

```typescript
// 站内信/聊天预留
interface ChatService {
  sendMessage(fromUserId: string, toUserId: string, content: string): Promise<Message>;
  getConversation(userId: string, targetUserId: string): Promise<Message[]>;
  getUnreadCount(userId: string): Promise<number>;
}

// 预留接口实现（数据存储但不实时推送）
export const mockChatService: ChatService = {
  sendMessage: async (from, to, content) => {
    // 保存到数据库但不实现WebSocket推送
    const message = { id: generateId(), from, to, content, created_at: new Date() };
    console.log(`[MOCK CHAT] 消息已存储:`, message);
    return message;
  },
  getConversation: async () => [],
  getUnreadCount: async () => 0
};
```

